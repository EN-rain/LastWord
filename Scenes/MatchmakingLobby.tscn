[node name="LabelPrivacy" type="Label" parent="Root/VBox"]
text = ""
theme_override_colors/font_color = Color(0.7, 0.78, 0.74, 1)
autowrap_mode = 3

[node name="ChatPanel" type="VBoxContainer" parent="Root/VBox"]
theme_override_constants/separation = 8

[node name="ChatLog" type="RichTextLabel" parent="Root/VBox/ChatPanel"]
custom_minimum_size = Vector2(0, 180)
bbcode_enabled = true
text = "[b]System:[/b] Welcome to the lobby."

[node name="HBox" type="HBoxContainer" parent="Root/VBox/ChatPanel"]
theme_override_constants/separation = 8

[node name="ChatInput" type="LineEdit" parent="Root/VBox/ChatPanel/HBox"]
