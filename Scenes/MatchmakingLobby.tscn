[node name="Root" type="PanelContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="Root"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="LabelTitle" type="Label" parent="Root/VBox"]
theme_override_colors/font_color = Color(0.95, 0.68, 0.24, 1)
theme_override_font_sizes/font_size = 28
text = "ONLINE MATCHMAKING LOBBY"
horizontal_alignment = 1

[node name="LabelRoomCode" type="Label" parent="Root/VBox"]
theme_override_colors/font_color = Color(0.62, 0.86, 0.66, 1)
theme_override_font_sizes/font_size = 18
text = "ROOM CODE: ..."
horizontal_alignment = 1

[node name="LabelPlayerCount" type="Label" parent="Root/VBox"]
theme_override_colors/font_color = Color(0.7, 0.78, 0.74, 1)
text = "PLAYERS: 0 / 4"
horizontal_alignment = 1

[node name="PlayerList" type="ItemList" parent="Root/VBox"]
custom_minimum_size = Vector2(0, 180)

[node name="HBoxRole" type="HBoxContainer" parent="Root/VBox"]
theme_override_constants/separation = 12

[node name="LabelRole" type="Label" parent="Root/VBox/HBoxRole"]
custom_minimum_size = Vector2(80, 0)
text = "ROLE:"
vertical_alignment = 1

[node name="OptionRole" type="OptionButton" parent="Root/VBox/HBoxRole"]
