PlayerListPath = NodePath("Root/VBox/PlayerList")
ChatLogPath = NodePath("Root/VBox/ChatPanel/ChatLog")
ChatInputPath = NodePath("Root/VBox/ChatPanel/HBox/ChatInput")
SendBtnPath = NodePath("Root/VBox/ChatPanel/HBox/BtnSend")
ReadyBtnPath = NodePath("Root/VBox/HBoxButtons/BtnReady")
CancelBtnPath = NodePath("Root/VBox/HBoxButtons/BtnCancel")
OrientationLabelPath = NodePath("Root/VBox/LabelOrientation")
ConsentLabelPath = NodePath("Root/VBox/LabelConsent")
PrivacyLabelPath = NodePath("Root/VBox/LabelPrivacy")
