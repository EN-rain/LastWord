[node name="LabelOrientation" type="Label" parent="Root/VBox"]
text = ""
visible = false

[node name="LabelConsent" type="Label" parent="Root/VBox"]
text = ""
autowrap_mode = 3

[node name="LabelPrivacy" type="Label" parent="Root/VBox"]
text = ""
autowrap_mode = 3

[node name="ChatPanel" type="VBoxContainer" parent="Root/VBox"]

[node name="ChatLog" type="RichTextLabel" parent="Root/VBox/ChatPanel"]
