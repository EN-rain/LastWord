[connection signal="item_selected" from="Root/VBox/HBoxRole/OptionRole" to="." method="OnRoleSelected"]

[node name="LabelOrientation" type="Label" parent="Root/VBox"]
text = ""
visible = false

[node name="LabelConsent" type="Label" parent="Root/VBox"]
