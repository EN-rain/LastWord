[connection signal="pressed" from="Root/VBox/HBoxButtons/BtnCancel" to="." method="OnCancelPressed"]
[connection signal="pressed" from="Root/VBox/HBoxButtons/BtnReady" to="." method="OnReadyPressed"]
[connection signal="pressed" from="Root/VBox/ChatPanel/HBox/BtnSend" to="." method="OnSendPressed"]
